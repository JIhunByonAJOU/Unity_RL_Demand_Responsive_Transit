# Normalize text files.
* text=auto

# Unity YAML assets should stay text and use Unity's YAML merge driver when configured.
*.asmdef text eol=lf merge=unityyamlmerge
*.asmref text eol=lf merge=unityyamlmerge
*.asset text eol=lf merge=unityyamlmerge
*.controller text eol=lf merge=unityyamlmerge
*.mat text eol=lf merge=unityyamlmerge
*.meta text eol=lf merge=unityyamlmerge
*.overrideController text eol=lf merge=unityyamlmerge
*.physicMaterial text eol=lf merge=unityyamlmerge
*.physicsMaterial2D text eol=lf merge=unityyamlmerge
*.playable text eol=lf merge=unityyamlmerge
*.prefab text eol=lf merge=unityyamlmerge
*.renderTexture text eol=lf merge=unityyamlmerge
*.unity text eol=lf merge=unityyamlmerge

# Common source/config text.
*.cs text eol=lf
*.cginc text eol=lf
*.compute text eol=lf
*.hlsl text eol=lf
*.shader text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Binary assets.
*.a binary
*.aar binary
*.ai binary
*.apk binary
*.dll binary
*.exe binary
*.fbx binary
*.gif binary
*.jpg binary
*.jpeg binary
*.mp3 binary
*.mp4 binary
*.ogg binary
*.pdf binary
*.png binary
*.psd binary
*.so binary
*.tga binary
*.ttf binary
*.wav binary
*.zip binary
